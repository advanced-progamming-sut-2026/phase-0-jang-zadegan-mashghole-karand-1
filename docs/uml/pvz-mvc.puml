@startuml PVZ2_MVC_Architecture

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam defaultFontSize 11

title Plants vs. Zombies 2 — MVC Architecture

class Application {
  + main()
  + run()
  + shutdown()
}

class CommandParser {
  + parse()
  + dispatch()
}

interface Controller {
  + handle()
}

Application --> CommandParser
CommandParser ..> Controller

package "Model" #E8F4FD {

  package "user" {
    class User {
      - username: String
      - passwordHash: String
      - gameProgress: GameProgress
    }

    class GameProgress {
      - completedLevels: Set<String>
      - unlockedChapters: Set<ChapterType>
      - unlockedMinigames: Set<MinigameType>
    }

    class UserRepository {
      + findByUsername()
      + register()
      + save()
    }
  }

  package "menu" {
    enum MenuType {
      REGISTER
      LOGIN
      MAIN
      PLAY
      SETTINGS
      NEWS
      PROFILE
      COLLECTION
      PLANT_SELECTION
      GAME
      GREENHOUSE
      SHOP
      TRAVEL_LOG
      LEADERBOARD
    }

    class MenuManager {
      - currentMenu: MenuType
      - userInput: String
      + getCurrentMenu()
      + changeMenu()
      + readInput()
    }
  }

  package "game" {
    enum GameStatus {
      PLANT_SELECTION
      IN_PROGRESS
      WON
      LOST
      PAUSED
    }

    class GameSession {
      - status: GameStatus
      - sunAmount: int
      - board: GameBoard
      - waveManager: WaveManager
      - sunManager: SunManager
    }

    class GameBoard {
      - tiles: Tile[][]
      - lawnMowers: LawnMower[]
    }

    class Tile {
      - position: Position
      - tileType: TileType
    }

    class Position {
      - x: int
      - y: int
    }
  }

  package "plant" {
    enum PlantKind

    enum PlantCategory {
      SUN_PRODUCER
      SHOOTER
      LOBBER
      EXPLOSIVE
      MELEE
      DEFENDER
      MODIFIER
      STRIKE_THROUGH
      HOMING
      MINT
    }

    abstract class Plant {
      - kind: PlantKind
      - hp: int
      - sunCost: int
      - position: Position
      - attackPower: int
    }

    class SunProducerPlant
    class ShooterPlant
    class LobberPlant
    class ExplosivePlant
    class DefenderPlant
    class ModifierPlant

    class PlantFactory {
      + create()
    }
  }

  package "zombie" {
    abstract class Zombie {
      - hp: int
      - speed: float
      - damageToPlants: int
      - abilities: List<String>
      - position: Position
    }

    class WalkerZombie
    class BossZombie
    class ImpZombie
    class PusherZombie
    class AbilityZombie

    class ZombieWave {
      - waveNumber: int
      - zombies: List<Zombie>
      - delay: int
    }

    class WaveManager {
      - waves: List<ZombieWave>
      - currentWaveNumber: int
    }

    class ZombieFactory {
      + create()
    }
  }

  package "sun" {
    class Sun {
      - amount: int
      - location: Position
      - remainingTime: int
    }

    class SunManager {
      - balance: int
      - activeSuns: List<Sun>
    }
  }

  package "projectile" {
    class Projectile {
      - damage: int
      - location: Position
      - speed: float
    }
  }

  package "lawnmower" {
    class LawnMower {
      - row: int
      - active: boolean
      + destroyZombiesInRow()
    }
  }

  package "world" {
    enum ChapterType {
      ANCIENT_EGYPT
      FROSTBITE_CAVES
      BIG_WAVE_BEACH
      DARK_AGES
    }

    class Chapter {
      - type: ChapterType
      - specialAbilities: List<String>
      - roadmap: List<Level>
    }

    class Level {
      - chapter: Chapter
      - levelNumber: int
    }

    enum SpecialLevelType {
      CONVEYOR_BELT
      LOCKED_PLANTS
      SAVE_OUR_SEEDS
      TIMED_WAR
      NIGHT_OPS
      DEAD_LINE
      LOVE_YOUR_PLANTS
      PLANT_WHAT_YOU_GET
    }

    class SpecialLevel {
      - kind: SpecialLevelType
      - plantsList: List<PlantKind>
      - attackPattern: String
    }
  }

  package "minigame" {
    enum MinigameType {
      VASEBREAKER
      WALLNUT_BOWLING
      I_ZOMBIE
      BEGHOULED
      ZOMBOTANY
    }

    abstract class Minigame {
      - type: MinigameType
      - specialRules: List<String>
    }

    class VasebreakerMinigame
    class WallnutBowlingMinigame
    class IZombieMinigame
    class BeghouledMinigame
    class ZombotanyMinigame
  }

  package "quest" {
    class Quest {
      - description: String
      - progress: int
      - target: int
      - completed: boolean
    }
  }

  package "collection" {
    class Collection {
      - unlockedPlants: Set<PlantKind>
      - lockedPlants: Set<PlantKind>
      + unlockPlant()
      + isUnlocked()
    }
  }

  package "greenhouse" {
    class Greenhouse {
      - lastHarvest: LocalDateTime
      - production: List<Pot>
    }

    class Pot {
      - position: Position
      - locked: boolean
    }
  }

  package "shop" {
    enum ShopItemType {
      PERMANENT
      DAILY
    }

    class ShopItem {
      - id: String
      - name: String
      - price: int
      - itemType: ShopItemType
    }

    class Shop {
      - permanentItems: List<ShopItem>
      - dailyItems: List<ShopItem>
    }

    class DailyDeal {
      - plantKind: PlantKind
      - discountedPrice: int
      - purchased: boolean
    }
  }

  package "news" {
    class NewsItem {
      - message: String
      - read: boolean
      - timestamp: LocalDateTime
    }

    class NewsFeed {
      - newsList: List<NewsItem>
      + hasUnread()
      + markAsRead()
    }
  }

  class AuthService
  class GameService
  class PersistenceManager
}

package "View" #FFF8E8 {

  abstract class View {
    + display()
    + showError()
  }

  class AuthView
  class MainMenuView
  class GameMenuView
  class GameView
  class MetaView
}

package "Controller" #F0F8E8 {

  class AuthController
  class MenuController
  class GameController
  class MetaController
}

User *-- GameProgress
User o-- Collection
User o-- Greenhouse
User o-- NewsFeed
User o-- Quest

MenuManager --> MenuType

GameSession --> GameStatus
GameSession *-- GameBoard
GameSession *-- WaveManager
GameSession *-- SunManager
GameBoard *-- Tile
GameBoard *-- LawnMower
Tile --> Position
Tile o-- Plant
Tile o-- Zombie

Plant --> PlantKind
Plant --> PlantCategory
Plant <|-- SunProducerPlant
Plant <|-- ShooterPlant
Plant <|-- LobberPlant
Plant <|-- ExplosivePlant
Plant <|-- DefenderPlant
Plant <|-- ModifierPlant
ShooterPlant ..> Projectile
LobberPlant ..> Projectile
PlantFactory ..> Plant

Zombie <|-- WalkerZombie
Zombie <|-- BossZombie
Zombie <|-- ImpZombie
Zombie <|-- PusherZombie
Zombie <|-- AbilityZombie
WaveManager *-- ZombieWave
ZombieWave o-- Zombie
ZombieFactory ..> Zombie

SunManager o-- Sun
Sun --> Position

Chapter --> ChapterType
Chapter *-- Level
Level <|-- SpecialLevel
SpecialLevel --> SpecialLevelType

Minigame --> MinigameType
Minigame <|-- VasebreakerMinigame
Minigame <|-- WallnutBowlingMinigame
Minigame <|-- IZombieMinigame
Minigame <|-- BeghouledMinigame
Minigame <|-- ZombotanyMinigame

Shop *-- ShopItem
Shop o-- DailyDeal
ShopItem --> ShopItemType
NewsFeed *-- NewsItem

PersistenceManager --> User
AuthService --> User
GameService --> GameSession
GameService --> Chapter
GameService --> PlantFactory
GameService --> ZombieFactory

View <|-- AuthView
View <|-- MainMenuView
View <|-- GameMenuView
View <|-- GameView
View <|-- MetaView

Controller <|.. AuthController
Controller <|.. MenuController
Controller <|.. GameController
Controller <|.. MetaController

AuthController --> AuthService
AuthController --> AuthView
MenuController --> MenuManager
MenuController --> MainMenuView
MenuController --> GameMenuView
GameController --> GameService
GameController --> GameView
MetaController --> Greenhouse
MetaController --> Shop
MetaController --> Quest
MetaController --> NewsFeed
MetaController --> MetaView

@enduml
